PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# Database
# Dev: use local SQLite file — no account needed
# Prod: get URL + token from turso.tech
TURSO_URL=file:local.db
TURSO_AUTH_TOKEN=

# Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret

# Email
# Dev: create free test account at https://ethereal.email
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Stash Panda <noreply@stashpanda.app>"

# BoardGameGeek
# BGG now requires a free account to use the XML API.
# Sign up at https://boardgamegeek.com/register/account
BGG_USERNAME=
BGG_PASSWORD=

# File storage
# Dev: local filesystem
UPLOAD_DIR=./uploads
# Prod: Cloudflare R2 (S3-compatible) — uncomment when ready
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=stash-panda
# R2_PUBLIC_URL=
